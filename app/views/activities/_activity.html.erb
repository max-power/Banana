<li class="activity-card" id="<%= dom_id(activity) %>">
  <% if activity.respond_to?(:geojson_path) && (svg_d = activity_svg_path(activity.geojson_path)) %>
    <div class="activity-card-map">
      <svg viewBox="0 0 200 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="<%= svg_d %>" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  <% end %>
  <div class="activity-card-body">
    <p class="activity-card-meta">
      <span class="activity-card-type"><%= activity.activity_type&.humanize || "Activity" %></span>
      <% if activity.start_time %>
        &middot; <span class="activity-card-date"><%= l(activity.start_time, format: :short) %></span>
      <% end %>
      <% if activity.duplicate_of_id %>
        &middot; <span class="duplicate-badge">duplicate</span>
      <% end %>
    </p>
    <h3 class="activity-card-name"><%= link_to activity.name.presence || "Untitled", activity_path(activity) %></h3>
    <dl class="activity-card-stats">
      <div><dt>Distance</dt><dd><%= format_distance(activity.distance) %></dd></div>
      <div><dt>Elevation</dt><dd>↑ <%= format_elevation(activity.elevation_gain) %></dd></div>
      <div><dt>Time</dt><dd><%= format_duration(activity.moving_time) %></dd></div>
    </dl>
  </div>
  <div class="activity-card-actions">
    <%= link_to "Edit", edit_activity_path(activity) %>
  </div>
</li>
