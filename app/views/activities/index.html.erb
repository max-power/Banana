<% content_for :title, "Activities" %>

<div class="activities-index-header">
  <h1>Activities</h1>
  <%= link_to "+ New Tour", new_tour_path, class: "btn-secondary" %>
</div>

<%= form_with url: activities_path, method: :get, class: "activity-toolbar" do |f| %>
  <%= f.search_field :q, value: params[:q], placeholder: "Search…", class: "activity-search-input" %>
  <%= select_tag :type,
        grouped_options_for_select(
          ActivityType.for_select,
          params[:type],
          prompt: "All types"
        ),
        class: "activity-toolbar-select",
        onchange: "this.form.requestSubmit()" %>
  <%= select_tag :year,
        options_for_select([["All years", ""]] + @years.map { |y| [y, y] }, params[:year]),
        class: "activity-toolbar-select",
        onchange: "this.form.requestSubmit()" %>
  <%= select_tag :sort,
        options_for_select([
          ["Newest first",   "date_desc"],
          ["Oldest first",   "date_asc"],
          ["Longest",        "distance_desc"],
          ["Most elevation", "elevation_desc"],
          ["Name A–Z",       "name_asc"],
        ], params[:sort] || "date_desc"),
        class: "activity-toolbar-select",
        onchange: "this.form.requestSubmit()" %>
  <%= f.hidden_field :view, value: @view %>
  <div class="view-toggle">
    <%= link_to activities_path(request.query_parameters.merge("view" => "cards")),
          class: "view-toggle-btn #{"active" if @view == "cards"}",
          title: "Card view" do %>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/>
        <rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/>
      </svg>
    <% end %>
    <%= link_to activities_path(request.query_parameters.merge("view" => "list")),
          class: "view-toggle-btn #{"active" if @view == "list"}",
          title: "List view" do %>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <rect x="1" y="2" width="14" height="2" rx="1"/><rect x="1" y="7" width="14" height="2" rx="1"/>
        <rect x="1" y="12" width="14" height="2" rx="1"/>
      </svg>
    <% end %>
  </div>
<% end %>

<div class="activities-index">
  <% if @activities.empty? %>
    <p class="empty-state">No activities yet. <%= link_to "Upload a GPX file", upload_path %> to get started.</p>
  <% else %>
    <% if @view == "list" %>
      <ul class="activity-feed activity-feed--compact">
        <%= render partial: "activities/activity_row", collection: @activities, as: :activity %>
      </ul>
    <% else %>
      <ul class="activity-feed">
        <%= render @activities %>
      </ul>
    <% end %>
  <% end %>

  <%= raw @pagy.series_nav if @pagy.pages > 1 %>
</div>
