<article>
    <header>
        <h1>
            <%= link_to @month.year, year_calendar_path(@month.year) %>
            <%= @month.month_name %>
        </h1>
        <p>
            <%= link_to @month.prev.month_name, month_calendar_path(@month.prev.year, @month.prev.number) %>
            <%= link_to @month.next.month_name, month_calendar_path(@month.next.year, @month.next.number) %>
        </p>
    </header>

    <% @month.each_week do |week| %>
        <article class="calendar-week">
            <h2><%= week %></h2>
            <p><%= l(week.begin, format: :short) %> - <%= l(week.end, format: :short) %></p>
            <ul>
            <% week.each_day do |date| %>
                <li>
                    <div class="calendar-dayname"><%= Date::ABBR_DAYNAMES[date.wday] %></div>
                    <% activities = @activities.select { |a| a.start_time.to_date == date } %>
                    <% if activities.present? %>
                        <div class="day-bubble"><%= format_distance activities.sum(&:distance) %></div>
                    <% else %>
                        <div class="day-rest">Rest</div>
                    <% end %>
                </li>
            <% end %>
            </ul>
        </article>
    <% end %>

    <section class="activities">
        <%= render partial: "activities/activity_calendar", collection: @activities, as: :activity %>
    </section>


</article>


<style>
.calendar-week {
    margin-block: 4rem;
    h2, p {
        font-weight: 400;
        font-size: 0.8rem;
    }
    h2 {display: none;}
    ul {
        list-style: none;
        margin:0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        justify-items: center;
        gap: 1rem;
    }

    li {
        display: grid;
        gap: 1rem;
        justify-items: center;
    }
    .calendar-dayname {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: #808080;
    }

    .day-bubble {
        background: var(--brand);
        border-radius: 50vw;
        width: 70px;
        aspect-ratio: 1;
        display: grid;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
    }
    .day-rest {
        color: #ccc;
        font-size: 0.7rem;
    }
}
</style>
