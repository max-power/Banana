<% content_for :title, @year.to_s %>

<article class="year-calendar">
    <header class="year-header">
        <div class="year-nav">
            <%= link_to "←", year_calendar_path(@year.prev) %>
            <h1><%= @year %></h1>
            <%= link_to "→", year_calendar_path(@year.next) %>
        </div>

        <dl class="calendar-stats">
            <div class="stat">
                <dt>kilometers</dt>
                <dd class="number"><%= number_with_delimiter((@statistics.sum(&:distance) / 1000).round) %></dd>
            </div>
            <!--<div class="stat">
                <dt>elevation</dt>
                <dd class="number"><%= number_with_delimiter(@statistics.sum(&:elevation_gain).round) %> m</dd>
            </div>-->
            <div class="stat">
                <dt>hours</dt>
                <dd class="number"><%= (@statistics.sum(&:moving_time) / 3600.0).round %></dd>
            </div>
            <div class="stat">
                <dt>activities</dt>
                <dd class="number"><%= @statistics.sum(&:activities_count) %></dd>
            </div>
        </dl>
    </header>

    <%# Activity sparkline — one bar per day of the year %>
    <% max_distance = @daily_distances.map { |d| d[:distance] }.max.to_f %>
    <div class="year-sparkline" title="Daily distance throughout <%= @year %>">
        <% @daily_distances.each do |day| %>
            <% pct = max_distance > 0 ? (day[:distance] / max_distance * 100).round : 0 %>
            <span class="sparkline-bar" style="height: <%= pct %>%"
                  title="<%= day[:date].strftime('%b %-d') %>: <%= format_distance(day[:distance]) %>"></span>
        <% end %>
    </div>

    <section class="calendar-year">
        <% @year.each_month do |month| %>
            <%= link_to month_calendar_path(@year, month.number) do %>
                <article class="month">
                    <header><%= month.month_abbr %></header>

                    <% stat = @statistics.find { it.month == month } %>
                    <p class="month-distance number"><%= "#{(stat.distance / 1000).round(0)} km" if stat %></p>

                    <div class="graph">
                        <% month_days = @daily_distances.select { |d| d[:date].month == month.number } %>
                        <% month_max = month_days.map { |d| d[:distance] }.max.to_f %>
                        <ul>
                            <% month_days.each do |day| %>
                                <% bar_pct = month_max > 0 ? (day[:distance] / month_max * 100).round : 0 %>
                                <li style="height: <%= [bar_pct, 2].max %>%"
                                    class="<%= 'active' if day[:activities_count] > 0 %>"></li>
                            <% end %>
                        </ul>
                    </div>
                </article>
            <% end %>
        <% end %>
    </section>
</article>
