<% content_for :title, @record.name.presence || "Activity" %>

<div class="activity-show">
  <header class="activity-header">
    <div class="activity-header-main">
      <% if @record.is_a?(Tour) %>
        <p class="activity-type">Tour &middot; <%= pluralize(@record.days, "day") %></p>
      <% else %>
        <p class="activity-type"><%= @record.activity_type&.humanize %></p>
      <% end %>
      <h1><%= @record.name.presence || "Untitled" %></h1>
      <p class="activity-date"><%= @record.start_time ? l(@record.start_time, format: :long) : "—" %></p>
    </div>
    <% if @owner.public_profile? %>
      <nav class="activity-actions">
        <%= link_to "← #{@owner.email}", public_profile_path(@owner) %>
      </nav>
    <% end %>
  </header>

  <dl class="activity-stats-bar">
    <div class="stat-bar-item">
      <dt>Distance</dt>
      <dd><%= format_distance(@record.distance) %></dd>
    </div>
    <div class="stat-bar-item">
      <dt>Moving time</dt>
      <dd><%= format_duration(@record.moving_time) %></dd>
    </div>
    <div class="stat-bar-item">
      <dt>Elapsed time</dt>
      <dd><%= format_duration(@record.elapsed_time) %></dd>
    </div>
    <div class="stat-bar-item">
      <dt>↑ Elevation gain</dt>
      <dd><%= format_elevation(@record.elevation_gain) %></dd>
    </div>
    <div class="stat-bar-item">
      <dt>↓ Elevation loss</dt>
      <dd><%= format_elevation(@record.elevation_loss) %></dd>
    </div>
    <% unless @record.is_a?(Tour) %>
      <div class="stat-bar-item">
        <dt>Avg speed</dt>
        <dd><%= format_speed(@record.average_speed, activity_type: @record.try(:activity_type)) %></dd>
      </div>
      <div class="stat-bar-item">
        <dt>Max speed</dt>
        <dd><%= format_speed(@record.max_speed, activity_type: @record.try(:activity_type)) %></dd>
      </div>
    <% end %>
  </dl>

  <div data-controller="activity-map"
    data-activity-map-url-value="<%= shared_activity_url(@record.share_token, format: :geojson) %>"
    data-activity-map-arrow-url-value="<%= asset_path('arrow-right.svg') %>">
    <figure class="activity-map" data-activity-map-target="map">
      <div class="map-playbar">
        <button class="map-play-btn" data-activity-map-target="playButton"
                data-action="click->activity-map#togglePlay" disabled>▶</button>
        <div class="map-timeline" data-activity-map-target="timeline">
          <div class="map-timeline-track"
               data-activity-map-target="timelineTrack"
               data-action="mousedown->activity-map#seekStart">
            <div class="map-timeline-fill" data-activity-map-target="timelineFill"></div>
            <div class="map-timeline-thumb" data-activity-map-target="timelineThumb"></div>
          </div>
          <span class="map-timeline-label" data-activity-map-target="timelineLabel"></span>
        </div>
      </div>
      <%= render "shared/map_style_switcher" %>
    </figure>
    <figure class="activity-elevation" data-activity-map-target="elevation"></figure>
  </div>

  <div class="share-embed">
    <p class="share-embed-label">Embed</p>
    <input class="share-embed-code" readonly
           value='<iframe src="<%= embed_activity_url(@record.share_token) %>" width="600" height="400" frameborder="0" style="border-radius:8px"></iframe>'
           onclick="this.select()">
  </div>
</div>
