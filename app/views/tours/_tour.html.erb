<li class="activity-card tour-card" id="<%= dom_id(tour) %>">
  <details class="tour-card-details">
    <summary class="tour-card-summary">
      <div class="activity-card-map">
        <% if StaticMapService.available? %>
          <%= activity_map_png(tour) %>
        <% else %>
          <%= activity_map_svg(tour) %>
        <% end %>
      </div>
      <div class="activity-card-body">
        <p class="activity-card-meta">
          <span class="activity-card-type">Tour &middot; <%= pluralize(tour.days, "day") %></span>
          <% if tour.start_time %>
            &middot; <span class="activity-card-date">
              <%= l(tour.start_time, format: :short) %>
              <% if tour.end_time && tour.end_time.to_date != tour.start_time.to_date %>
                – <%= l(tour.end_time, format: :short) %>
              <% end %>
            </span>
          <% end %>
        </p>
        <h3 class="activity-card-name"><%= link_to tour.name.presence || "Untitled Tour", tour_path(tour) %></h3>
        <dl class="activity-card-stats">
          <div><dt>Distance</dt><dd><%= format_distance(tour.distance) %></dd></div>
          <div><dt>Elevation</dt><dd>↑ <%= format_elevation(tour.elevation_gain) %></dd></div>
          <div><dt>Time</dt><dd><%= format_duration(tour.moving_time) %></dd></div>
        </dl>
      </div>
    </summary>

    <ul class="tour-card-activities">
      <% tour.activities.each do |activity| %>
        <%= render "activities/activity_row", activity: activity %>
      <% end %>
    </ul>
  </details>
</li>
