<% content_for :title, @tour.name.presence || "Tour" %>

<div class="activity-show">
  <header class="activity-header">
    <div class="activity-header-main">
      <p class="activity-type">Tour &middot; <%= pluralize(@tour.days, "day") %></p>
      <h1><%= @tour.name.presence || "Untitled Tour" %></h1>
      <% if @tour.start_time %>
        <p class="activity-date">
          <%= l(@tour.start_time, format: :long) %>
          <% if @tour.end_time && @tour.end_time.to_date != @tour.start_time.to_date %>
            – <%= l(@tour.end_time, format: :long) %>
          <% end %>
        </p>
      <% end %>
    </div>
    <nav class="activity-actions">
      <button class="share-btn" data-share-url="<%= shared_activity_url(@tour.share_token) %>"
              onclick="navigator.clipboard.writeText(this.dataset.shareUrl).then(() => { this.textContent = 'Copied!'; setTimeout(() => this.textContent = 'Share', 2000) })">Share</button>
      <%= link_to "Edit", edit_tour_path(@tour) %>
      <%= link_to "← Back", activities_path %>
    </nav>
  </header>

  <% if @tour.description.present? %>
    <div class="activity-notes">
      <%= simple_format(@tour.description) %>
    </div>
  <% end %>

  <dl class="activity-stats-bar">
    <div class="stat-bar-item">
      <dt>Distance</dt>
      <dd><%= format_distance(@tour.distance) %></dd>
    </div>
    <div class="stat-bar-item">
      <dt>Moving time</dt>
      <dd><%= format_duration(@tour.moving_time) %></dd>
    </div>
    <div class="stat-bar-item">
      <dt>Elapsed time</dt>
      <dd><%= format_duration(@tour.elapsed_time) %></dd>
    </div>
    <div class="stat-bar-item">
      <dt>↑ Elevation gain</dt>
      <dd><%= format_elevation(@tour.elevation_gain) %></dd>
    </div>
    <div class="stat-bar-item">
      <dt>↓ Elevation loss</dt>
      <dd><%= format_elevation(@tour.elevation_loss) %></dd>
    </div>
  </dl>

  <% if @tour.activities.any? %>
    <div data-controller="activity-map"
      data-activity-map-url-value="<%= tour_url(@tour, format: :geojson) %>"
      data-activity-map-arrow-url-value="<%= asset_path('arrow-right.svg') %>">
      <figure class="activity-map" data-activity-map-target="map">
        <div class="map-playbar">
          <button class="map-play-btn" data-activity-map-target="playButton"
                  data-action="click->activity-map#togglePlay" disabled>▶</button>
          <div class="map-timeline" data-activity-map-target="timeline">
            <div class="map-timeline-track"
                 data-activity-map-target="timelineTrack"
                 data-action="mousedown->activity-map#seekStart">
              <div class="map-timeline-fill" data-activity-map-target="timelineFill"></div>
              <div class="map-timeline-thumb" data-activity-map-target="timelineThumb"></div>
            </div>
            <span class="map-timeline-label" data-activity-map-target="timelineLabel"></span>
          </div>
        </div>
        <%= render "shared/map_style_switcher" %>
      </figure>
      <figure class="activity-elevation" data-activity-map-target="elevation"></figure>
    </div>

    <section class="tour-days">
      <h2>Activities</h2>
      <ul class="tour-card-activities tour-days-list">
        <% @tour.activities.each_with_index do |activity, i| %>
          <%= render "activities/activity_row", activity: activity %>
        <% end %>
      </ul>
    </section>
  <% else %>
    <p class="empty-state">
      No activities in this tour yet. <%= link_to "Add some", edit_tour_path(@tour) %>.
    </p>
  <% end %>
</div>
